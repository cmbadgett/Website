---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  tagline: string;
  description: string;
  tags: string[];
  status: 'active' | 'completed' | 'wip';
  coverImage: string;
  githubUrl?: string;
  liveUrl?: string;
}

const { title, tagline, description, tags, status, coverImage, githubUrl, liveUrl } = Astro.props;

const statusMap = {
  active:    { label: 'Active',     class: 'bg-accent-green/10 text-accent-green border-accent-green/30' },
  completed: { label: 'Completed',  class: 'bg-accent-cyan/10  text-accent-cyan  border-accent-cyan/30'  },
  wip:       { label: 'In Progress',class: 'bg-yellow-400/10   text-yellow-400   border-yellow-400/30'   },
};
const s = statusMap[status];
---

<BaseLayout title={title} description={description}>
  <div class="bg-bg-surface border-b border-border">
    <div class="container py-16 sm:py-24">
      <a
        href="/projects"
        class="inline-flex items-center gap-1.5 text-text-muted hover:text-accent-cyan font-mono text-sm transition-colors mb-8 group"
      >
        <span class="group-hover:-translate-x-0.5 transition-transform">←</span>
        cd /projects
      </a>

      <div class="flex flex-wrap items-start gap-3 mb-4">
        <span class={`tag border ${s.class} font-mono text-xs px-2.5 py-1`}>{s.label}</span>
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>

      <h1 class="section-title text-4xl sm:text-5xl mb-4">{title}</h1>
      <p class="text-text-muted font-mono text-lg mb-8">{tagline}</p>

      <div class="flex flex-wrap gap-3">
        {githubUrl && (
          <a href={githubUrl} class="btn-outline" target="_blank" rel="noopener noreferrer">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
          </a>
        )}
        {liveUrl && (
          <a href={liveUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
            </svg>
            Live Demo
          </a>
        )}
      </div>
    </div>
  </div>

  {coverImage && (
    <div class="border-b border-border">
      <div class="container py-0">
        <img
          src={coverImage}
          alt={`${title} cover`}
          class="w-full max-h-[480px] object-cover rounded-b-lg"
          loading="lazy"
        />
      </div>
    </div>
  )}

  <div class="container py-16">
    <div class="max-w-3xl">
      <slot />
    </div>
  </div>
</BaseLayout>
