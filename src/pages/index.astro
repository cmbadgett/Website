---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { projects } from '@/data/projects';

const featured = projects.filter(p => p.featured);
---

<BaseLayout title="Home">
  <!-- ── Hero ── -->
  <section class="relative min-h-[calc(100vh-3.5rem)] flex items-center overflow-hidden">
    <!-- Grid background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-40 pointer-events-none"></div>
    <!-- Radial glow -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent-cyan/5 blur-3xl pointer-events-none"></div>

    <div class="container relative z-10 py-20">
      <div class="max-w-3xl">
        <!-- Terminal prompt line -->
        <div class="font-mono text-sm text-text-muted mb-6 flex items-center gap-2">
          <span class="text-accent-green">cmbadgett</span>
          <span class="text-text-muted">@</span>
          <span class="text-accent-cyan">homelab</span>
          <span class="text-text-muted">:~$</span>
          <span class="text-text-primary">whoami</span>
          <span class="inline-block w-2 h-4 bg-accent-cyan animate-blink ml-0.5"></span>
        </div>

        <h1 class="font-mono text-5xl sm:text-6xl lg:text-7xl font-bold leading-none mb-6">
          <span class="text-text-primary">Christopher</span>
          <br />
          <span class="text-accent-cyan">Badgett</span>
        </h1>

        <div class="font-mono text-lg sm:text-xl text-text-muted mb-6 space-y-1">
          <p><span class="text-accent-purple">const</span> <span class="text-text-primary">roles</span> <span class="text-text-muted">=</span> <span class="text-accent-green">[</span></p>
          <p class="pl-6">'cybersecurity student',</p>
          <p class="pl-6">'homelab builder',</p>
          <p class="pl-6">'3D printing hobbyist',</p>
          <p><span class="text-accent-green">]</span></p>
        </div>

        <p class="text-text-muted font-sans text-base sm:text-lg leading-relaxed max-w-xl mb-10">
          I break things in controlled environments, build redundant storage systems at home,
          and turn spools of plastic into useful stuff. Currently studying cybersecurity
          and expanding my homelab one rack unit at a time.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/projects" class="btn-primary">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
            View Projects
          </a>
          <a href="/about" class="btn-outline">
            About Me
          </a>
          <a href="/contact" class="btn-ghost">
            Get in Touch →
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative side element -->
    <div class="absolute right-0 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-border to-transparent hidden lg:block"></div>
  </section>

  <!-- ── Stats bar ── -->
  <section class="border-y border-border bg-bg-surface">
    <div class="container py-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
        {[
          { value: '2 TB',   label: 'NAS capacity'       },
          { value: '2',      label: 'Pi cluster nodes'   },
          { value: '2',      label: 'Bambu Lab A1s'      },
          { value: '2',      label: 'active AI agents'   },
        ].map(({ value, label }) => (
          <div class="text-center">
            <p class="font-mono text-2xl sm:text-3xl font-bold text-accent-cyan">{value}</p>
            <p class="font-mono text-xs text-text-muted mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Featured Projects ── -->
  <section class="container py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="section-label">// selected work</p>
        <h2 class="section-title">Featured Projects</h2>
      </div>
      <a href="/projects" class="btn-ghost hidden sm:inline-flex">
        All projects →
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map(p => <ProjectCard project={p} />)}
    </div>

    <div class="mt-8 sm:hidden">
      <a href="/projects" class="btn-ghost">All projects →</a>
    </div>
  </section>

  <!-- ── Quick links ── -->
  <section class="border-t border-border bg-bg-surface">
    <div class="container py-20">
      <p class="section-label text-center">// explore</p>
      <h2 class="section-title text-center mb-12">What else is here</h2>

      <div class="grid sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {[
          {
            href: '/gallery',
            icon: `<path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
            title: '3D Print Gallery',
            desc: 'Functional parts, flexi toys, and workshop upgrades.',
          },
          {
            href: '/resume',
            icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
            title: 'Resume',
            desc: 'Skills, education, certs, and experience — on-page and as PDF.',
          },
          {
            href: '/contact',
            icon: `<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
            title: 'Contact',
            desc: 'Questions, opportunities, or just saying hello — reach out.',
          },
        ].map(({ href, icon, title, desc }) => (
          <a
            href={href}
            class="card p-6 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-1 transition-all duration-300 group"
          >
            <div class="w-10 h-10 rounded-lg bg-accent-cyan/10 border border-accent-cyan/20 flex items-center justify-center mb-4 group-hover:bg-accent-cyan/20 transition-colors">
              <svg class="w-5 h-5 text-accent-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={icon}></svg>
            </div>
            <h3 class="font-mono font-semibold text-text-primary group-hover:text-accent-cyan transition-colors mb-1">{title}</h3>
            <p class="text-text-muted text-sm font-sans leading-relaxed">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
